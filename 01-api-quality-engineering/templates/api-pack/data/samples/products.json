    },
    {
      "_case": "PROD-02 annual plan",
      "product_type": "subscription",
      "store_identifier": "starter.annual",
      "display_name": "Starter Annual",
      "duration": "P1Y"
    }
  ],
  "negative": [
    {
      "_case": "PROD-N01 missing product_type",
      "store_identifier": "missing.type"
    }
  ],
  "update": [
