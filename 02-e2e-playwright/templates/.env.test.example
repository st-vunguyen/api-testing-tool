# ─── E2E Test Environment Variables ─────────────────────
# Copy this file to `.env.test` at repo root and fill in values.
#
# ⚠️ Credentials (ADMIN_*, USER_*) belong in config/index.ts
#    with process.env fallback defaults — NOT in this file.
#    This file is for app-level env vars only.

# Application base URL
BASE_URL="http://localhost:3000"

# Database (TODO: update for your project's database)
# DATABASE_URL="postgresql://user:password@localhost:5432/app_test"

# Auth provider (TODO: update for your auth system)
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="e2e-test-secret-key-for-playwright-tests"
